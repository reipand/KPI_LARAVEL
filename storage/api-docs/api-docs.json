        "/api/v2/tenants": {
            "get": {
                "tags": [
                    "Tenants"
                ],
                "summary": "List all tenants (paginated)",
                "operationId": "671572354240e95ced976177b8636c54",
                "parameters": [
                    {
                        "name": "search",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "status",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "enum": [
                                "active",
                                "inactive",
                                "suspended"
                            ]
                        }
                    },
                    {
                        "name": "page",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Paginated tenant list"
                    },
                    "403": {
                        "description": "Forbidden — super_admin only"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "post": {
                "tags": [
                    "Tenants"
                ],
                "summary": "Create a new tenant",
                "operationId": "f546e35f79b5090a5c125a950235dbb7",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "tenant_code",
                                    "tenant_name"
                                ],
                                "properties": {
                                    "tenant_code": {
                                        "type": "string",
                                        "example": "COMP-001"
                                    },
                                    "tenant_name": {
                                        "type": "string",
                                        "example": "PT Example"
                                    },
                                    "domain": {
                                        "type": "string",
                                        "example": "app.example.com"
                                    },
                                    "status": {
                                        "type": "string",
                                        "enum": [
                                            "active",
                                            "inactive",
                                            "suspended"
                                        ]
                                    },
                                    "contact_email": {
                                        "type": "string",
                                        "example": "admin@example.com"
                                    },
                                    "contact_phone": {
                                        "type": "string",
                                        "example": "+628123456789"
                                    },
                                    "address": {
                                        "type": "string"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Tenant created"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
