        "/api/auth/login": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Login with NIP and Nama",
                "operationId": "dd51a484b7fa0f97c7680fdbde14cf5f",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "nip",
                                    "nama"
                                ],
                                "properties": {
                                    "nip": {
                                        "type": "string",
                                        "example": "EMP-001"
                                    },
                                    "nama": {
                                        "type": "string",
                                        "example": "Budi Santoso"
                                    },
                                    "device_name": {
                                        "type": "string",
                                        "example": "Chrome/Windows"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Login successful — returns bearer token and user"
                    },
                    "422": {
                        "description": "Invalid NIP or Nama"
                    },
                    "429": {
                        "description": "Too many attempts"
                    }
                }
            }
        },
