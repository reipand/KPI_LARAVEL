        "/auth/login": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Login pegawai",
                "operationId": "99d66635c4992aeaa6aa44ff653d0563",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "nip",
                                    "nama"
                                ],
                                "properties": {
                                    "nip": {
                                        "type": "string",
                                        "example": "198001012010011001"
                                    },
                                    "nama": {
                                        "type": "string",
                                        "example": "Budi Santoso"
                                    },
                                    "device_name": {
                                        "type": "string",
                                        "example": "Chrome"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Login berhasil — token dikembalikan"
                    },
                    "422": {
                        "description": "NIP atau nama tidak valid"
                    },
                    "429": {
                        "description": "Terlalu banyak percobaan"
                    }
                }
            }
        },
